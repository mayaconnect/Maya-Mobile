# Maya Connect V2 — Environment Variables
# Copy this file as .env and fill in your values.

# API Base URL (required)
# Local dev:   https://localhost:61802
# Azure dev:   https://maya-dev-api-cgc5agebeke0hxhq.francecentral-01.azurewebsites.net
# Production:  https://api.mayaconnect.fr
EXPO_PUBLIC_API_BASE_URL=https://maya-dev-api-cgc5agebeke0hxhq.francecentral-01.azurewebsites.net

# Google OAuth Client IDs
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# Stripe Publishable Key
EXPO_PUBLIC_STRIPE_PK=pk_live_YOUR_STRIPE_KEY

# Deep link scheme (should match app.json)
EXPO_PUBLIC_SCHEME=maya

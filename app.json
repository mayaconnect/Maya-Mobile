{
  "expo": {
    "name": "Maya-Connect",
    "slug": "maya-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "maya",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "backgroundColor": "#000000"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mayaconnect.app",
      "buildNumber": "1.0.0",
      "icon": "./assets/images/logo.png",
      "entitlements": {
        "com.apple.developer.applesignin": ["Default"]
      },
      "infoPlist": {
        "NSFaceIDUsageDescription": "Maya utilise Face ID pour sécuriser et simplifier votre connexion.",
        "NSCameraUsageDescription": "Maya a besoin d'accéder à votre caméra pour scanner les codes QR.",
        "NSLocationWhenInUseUsageDescription": "Maya a besoin de votre localisation pour vous montrer les magasins à proximité.",
        "NSPhotoLibraryUsageDescription": "Maya a besoin d'accéder à vos photos pour partager des contenus.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.maya.connect",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
      "owner": "glafay996",
    "extra": {
        "googleClientId": "125229396520-enrhsjtp80ehijnf0ru39n1j18ic2vqv.apps.googleusercontent.com",
        "router": {},
        "eas": {
          "projectId": "70138919-2611-4fa0-b38a-90919894c002"
        }
    }
  }
}